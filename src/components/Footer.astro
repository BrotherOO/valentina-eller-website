---

<footer
    class="bg-[#FFF5F2] border-t border-accent-warm/20 pt-16 pb-8 relative z-10"
>
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
            <!-- Brand -->
            <div class="col-span-1 md:col-span-1">
                <h4 class="font-bold text-gray-900 mb-4">Valentina Dubinsky</h4>
                <p class="text-gray-500 text-sm leading-relaxed mb-6">
                    Ihre Änderungsschneiderei in Düsseldorf-Eller. Wir bringen
                    Ihre Lieblingsstücke zurück ins Leben. Nachhaltig & mit
                    Herz.
                </p>
            </div>

            <!-- Links -->
            <div>
                <h4 class="font-bold text-gray-900 mb-4">Navigation</h4>
                <ul class="space-y-2 text-sm text-gray-600">
                    <li>
                        <a
                            href="/"
                            class="hover:text-accent-warm transition-colors"
                            >Zur Startseite</a
                        >
                    </li>
                    <li>
                        <a
                            href="/#preise"
                            class="hover:text-accent-warm transition-colors"
                            >Preisliste ansehen</a
                        >
                    </li>
                    <li>
                        <a
                            href="/ueber-uns"
                            class="hover:text-accent-warm transition-colors"
                            >Mehr über uns erfahren</a
                        >
                    </li>
                    <li>
                        <a
                            href="/#kontakt"
                            class="hover:text-accent-warm transition-colors"
                            >Kontakt aufnehmen</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Legal -->
            <div>
                <h4 class="font-bold text-gray-900 mb-4">Rechtliches</h4>
                <ul class="space-y-2 text-sm text-gray-600">
                    <li>
                        <a
                            href="/impressum"
                            class="hover:text-accent-warm transition-colors"
                            >Impressum</a
                        >
                    </li>
                    <li>
                        <a
                            href="/datenschutz"
                            class="hover:text-accent-warm transition-colors"
                            >Datenschutzerklärung</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Contact Short -->
            <div>
                <h4 class="font-bold text-gray-900 mb-4">Kontakt</h4>
                <ul class="space-y-3 text-sm text-gray-600">
                    <li class="flex items-start gap-2">
                        <span>📍</span>
                        <span>Dillenburger Weg 33a,<br /> 40229 Düsseldorf</span
                        >
                    </li>
                    <li class="flex items-center gap-2">
                        <span>📞</span>
                        <a
                            href="tel:021191737673"
                            class="hover:text-accent-warm transition-colors"
                            >0211 91737673</a
                        >
                    </li>
                </ul>
            </div>
        </div>

        <!-- Directory Backlinks (SEO) -->
        <section aria-label="Branchenverzeichnisse" class="mt-4 mb-12 border-t border-gray-100 pt-8 text-center md:text-left">
            <h4 class="font-bold text-gray-900 mb-4">Auch zu finden auf</h4>
            <ul class="flex flex-wrap items-center justify-center md:justify-start gap-4 md:gap-8 text-sm text-gray-600">
                <li>
                  <a href="https://www.dasoertliche.de/Themen/Dubinskiy-Valentina-Düsseldorf-Eller-Dillenburger-Weg"
                     target="_blank" rel="noopener noreferrer" class="hover:text-accent-warm transition-colors font-medium">
                    Das Örtliche
                  </a>
                </li>
                <li>
                  <a href="https://www.gelbeseiten.de/gsbiz/13f65120-2717-4113-a1a8-fe6073e44ac7"
                     target="_blank" rel="noopener noreferrer" class="hover:text-accent-warm transition-colors font-medium">
                    Gelbe Seiten
                  </a>
                </li>
                <li>
                  <a href="https://adresse.dastelefonbuch.de/Düsseldorf/1-Änderungsschneidereien-Valentina-Dubinskiy-Düsseldorf-Dillenburger-Weg.html"
                     target="_blank" rel="noopener noreferrer" class="hover:text-accent-warm transition-colors font-medium">
                    Das Telefonbuch
                  </a>
                </li>
                <li>
                  <a href="https://www.kaufda.de/Filialen/Duesseldorf/Chemische-Reinigung-Eller-Dillenburger-Weg-DHL-Paketshop/v-f1024825947"
                     target="_blank" rel="noopener noreferrer" class="hover:text-accent-warm transition-colors font-medium">
                    KaufDa
                  </a>
                </li>
                <li>
                  <a href="https://aenderungsschneidereiindernaehe.com/eintrag/deutschland/nordrhein-westfalen/duesseldorf/dubinskiy-valentina/"
                     target="_blank" rel="noopener noreferrer" class="hover:text-accent-warm transition-colors font-medium">
                    Änderungsschneiderei in der Nähe
                  </a>
                </li>
            </ul>
        </section>

        <div
            class="border-t border-gray-100 pt-8 mt-8 flex flex-col md:flex-row justify-between items-center w-full text-gray-500 gap-6"
        >
            <p class="text-xs text-center md:text-left order-2 md:order-1">
                &copy; {new Date().getFullYear()} Valentina Dubinskys Änderungsschneiderei.<br class="md:hidden" />
                Alle Rechte vorbehalten.
            </p>
            
            <div class="order-1 md:order-2 flex flex-col items-center text-center md:items-end md:text-right bg-white px-6 py-4 rounded-xl border border-accent-warm/10 shadow-sm shadow-accent-warm/5">
                <p class="text-gray-900 font-serif italic text-lg mb-1">
                    Design trifft Handwerk.
                </p>
                <p class="text-sm font-medium text-gray-700">
                    Webdesign und Konzeption by <a
                    href="https://dubinskiy.de"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-accent-warm hover:text-accent-warm-dark font-semibold transition-colors underline decoration-accent-warm/40 hover:decoration-accent-warm underline-offset-4"
                    >David Dubinskiy</a>
                </p>
            </div>
        </div>
    </div>
</footer>

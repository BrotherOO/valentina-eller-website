---
import "../styles/global.css";
import favicon from "../assets/valentina_favicon.png";
import CookieBanner from "../components/CookieBanner.vue";
import ClickRipple from "../components/ClickRipple.astro"; // Import ClickRipple
import Analytics from "@vercel/analytics/astro";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Änderungsschneiderei Düsseldorf-Eller | Valentinas Nähstube",
	description = "Änderungsschneiderei in Düsseldorf-Eller. Hose kürzen ab 8€, Lederreparatur & DHL Paketshop. Einfach vorbeikommen – keine Anmeldung nötig!",
} = Astro.props;
---

<!doctype html>
<html lang="de" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href={favicon.src} />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />

		<!-- OpenGraph Tags -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content="/_astro/schneiderinprofil.CXnuNw3p.jpg" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Valentina Dubinskaya – Ihre Schneiderin in Düsseldorf-Eller" />
		<meta property="og:locale" content="de_DE" />

		<meta
			http-equiv="Content-Security-Policy"
			content="default-src 'self'; script-src 'self' 'unsafe-inline' https://*.clarity.ms https://www.clarity.ms https://c.bing.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://api.dicebear.com https://*.clarity.ms https://www.clarity.ms https://c.bing.com https://*.google-analytics.com https://*.googletagmanager.com; frame-src https://www.google.com; connect-src 'self' https://*.clarity.ms https://www.clarity.ms https://c.bing.com https://*.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com; object-src 'none'; base-uri 'self';"
		/>
		<meta http-equiv="X-Content-Type-Options" content="nosniff" />
		<meta name="referrer" content="strict-origin-when-cross-origin" />
		<meta name="google-site-verification" content="IjbzOiLEXDwoDJ4qxTxDf7KSI54fB7aCcIXxV2IZh5Q" />

		<!-- Google Fonts: Playfair Display & Inter -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap"
			rel="stylesheet"
		/>

		<link rel="canonical" href="https://www.schneiderei-eller.de" />
		<title>{title}</title>

		<script type="application/ld+json">
		{
		  "@context": "https://schema.org",
		  "@type": "LocalBusiness",
		  "name": "Änderungsschneiderei Valentina Düsseldorf-Eller",
		  "url": "https://www.schneiderei-eller.de",
		  "telephone": "+49-211-91737673",
		  "address": {
		    "@type": "PostalAddress",
		    "streetAddress": "Dillenburger Weg 33A",
		    "addressLocality": "Düsseldorf",
		    "addressRegion": "Nordrhein-Westfalen",
		    "postalCode": "40229",
		    "addressCountry": "DE"
		  },
		  "openingHoursSpecification": [
		    {
		      "@type": "OpeningHoursSpecification",
		      "dayOfWeek": ["Monday","Tuesday","Thursday","Friday"],
		      "opens": "10:00",
		      "closes": "13:00"
		    },
		    {
		      "@type": "OpeningHoursSpecification",
		      "dayOfWeek": ["Monday","Tuesday","Thursday","Friday"],
		      "opens": "15:00",
		      "closes": "18:00"
		    },
		    {
		      "@type": "OpeningHoursSpecification",
		      "dayOfWeek": ["Wednesday","Saturday"],
		      "opens": "10:00",
		      "closes": "13:00"
		    }
		  ],
		  "sameAs": [
		    "https://www.dasoertliche.de/Themen/Dubinskiy-Valentina-Düsseldorf-Eller-Dillenburger-Weg",
		    "https://www.gelbeseiten.de/gsbiz/13f65120-2717-4113-a1a8-fe6073e44ac7",
		    "https://adresse.dastelefonbuch.de/Düsseldorf/1-Änderungsschneidereien-Valentina-Dubinskiy-Düsseldorf-Dillenburger-Weg.html",
		    "https://www.kaufda.de/Filialen/Duesseldorf/Chemische-Reinigung-Eller-Dillenburger-Weg-DHL-Paketshop/v-f1024825947",
		    "https://aenderungsschneidereiindernaehe.com/eintrag/deutschland/nordrhein-westfalen/duesseldorf/dubinskiy-valentina/"
		  ],
		  "priceRange": "€€",
		  "description": "Professionelle Änderungsschneiderei in Düsseldorf-Eller seit über 40 Jahren. Hosen kürzen ab 8 €, Lederreparatur & offizieller DHL Paketshop."
		}
		</script>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-RGGR8CFCYQ"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-RGGR8CFCYQ');
		</script>
		<script type="text/javascript" is:inline>
			(function (c, l, a, r, i, t, y) {
				c[a] =
					c[a] ||
					function () {
						(c[a].q = c[a].q || []).push(arguments);
					};
				t = l.createElement(r);
				t.async = 1;
				t.src = "https://www.clarity.ms/tag/" + i;
				y = l.getElementsByTagName(r)[0];
				y.parentNode.insertBefore(t, y);
			})(window, document, "clarity", "script", "vhcxnlmwtg");
		</script>
	</head>
	<body
		class="bg-primary text-gray-800 font-sans antialiased overflow-x-hidden selection:bg-highlight selection:text-gray-900"
	>
		<slot />
		<CookieBanner client:load />
		<ClickRipple />
		<Analytics />
	</body>
</html>

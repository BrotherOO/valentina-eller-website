---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.vue";
import Footer from "../components/Footer.astro";
---

<Layout
    title="Änderungsschneiderei Düsseldorf | ab 8 € | Kein Termin – Valentinas Nähstube"
    description="Änderungsschneiderei in Düsseldorf-Eller – Hose kürzen ab 8 €, Reißverschluss erneuern, Kleid anpassen. Kein Termin nötig. Seit über 40 Jahren. Jetzt vorbeikommen!"
>
    <Header client:load />

    <!-- JSON-LD Platzhalter -->
    <script type="application/ld+json">
    {
      // @TODO: Hier JSON-LD Block einfügen
    }
    </script>

    <main class="pt-32 pb-0 bg-neutral-50/30">
        
        <!-- 1. HERO -->
        <section class="container mx-auto px-4 max-w-6xl mt-4 mb-20 lg:flex lg:gap-12 items-center">
            <!-- Left -->
            <div class="lg:w-1/2">
                <div class="inline-block bg-white text-gray-800 text-sm font-semibold px-4 py-2 rounded-full mb-6 shadow-sm border border-gray-100">
                    📍 Düsseldorf-Eller · Seit über 40 Jahren
                </div>
                <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-[#122738] mb-6 leading-tight">
                    Änderungsschneiderei in Düsseldorf – schnell & fair.
                </h1>
                <p class="text-lg md:text-xl text-gray-600 mb-8 leading-relaxed">
                    Professionelle Kleidungsänderungen, Reparaturen und Anpassungen. Kein Termin nötig – einfach vorbeikommen. Bearbeitungszeit meist 1–2 Tage.
                </p>
                <div class="flex flex-col sm:flex-row gap-4">
                    <a href="#preise" class="inline-flex items-center justify-center gap-2 bg-[#e94470] text-white px-8 py-4 rounded-full font-bold shadow-lg hover:shadow-xl hover:scale-105 hover:bg-[#ca1245] transition-all">
                        Preise ansehen
                    </a>
                    <a href="#anfahrt" class="inline-flex items-center justify-center gap-2 bg-white text-[#122738] px-8 py-4 rounded-full font-bold shadow-sm border border-gray-200 hover:bg-gray-50 transition-all">
                        Anfahrt & Öffnungszeiten
                    </a>
                </div>
            </div>
            
            <!-- Right -->
            <div class="lg:w-1/2 mt-12 lg:mt-0 relative">
                <div class="absolute -inset-4 bg-gradient-to-r from-[#e94470]/10 to-[#f8dac2]/30 rounded-[2rem] blur-xl z-0"></div>
                <div class="relative z-10 bg-white rounded-2xl shadow-xl border border-gray-100 p-6 md:p-8">
                    <h3 class="text-xl font-bold text-[#122738] mb-6">Preisübersicht (Auszug)</h3>
                    <ul class="space-y-4 divide-y divide-gray-50">
                        <li class="flex justify-between pt-4 first:pt-0">
                            <span class="text-gray-700">Hose kürzen</span>
                            <span class="font-bold text-[#e94470]">ab 8 €</span>
                        </li>
                        <li class="flex justify-between pt-4">
                            <span class="text-gray-700">Hose kürzen (Originalnaht)</span>
                            <span class="font-bold text-[#e94470]">ab 18 €</span>
                        </li>
                        <li class="flex justify-between pt-4">
                            <span class="text-gray-700">Reißverschluss erneuern (Stoff)</span>
                            <span class="font-bold text-[#e94470]">ab 18 €</span>
                        </li>
                        <li class="flex justify-between pt-4">
                            <span class="text-gray-700">Reißverschluss (Lederjacke)</span>
                            <span class="font-bold text-[#e94470]">ab 35 €</span>
                        </li>
                        <li class="flex justify-between pt-4">
                            <span class="text-gray-700">Kleid / Abendmode anpassen</span>
                            <span class="font-bold text-[#e94470]">ab 14 €</span>
                        </li>
                        <li class="flex justify-between pt-4">
                            <span class="text-gray-700">Sakko kürzen & engen</span>
                            <span class="font-bold text-[#e94470]">ab 18 €</span>
                        </li>
                        <li class="flex justify-between pt-4">
                            <span class="text-gray-700">Mantel kürzen</span>
                            <span class="font-bold text-[#e94470]">ab 25 €</span>
                        </li>
                        <li class="flex justify-between pt-4">
                            <span class="text-gray-700">Hemd waschen & bügeln</span>
                            <span class="font-bold text-[#e94470]">3,50 €</span>
                        </li>
                    </ul>
                    <div class="mt-6 pt-6 border-t border-gray-100">
                        <p class="text-xs text-gray-500 italic mb-4">
                            Alle Preise sind Mindestpreise. Preis wird kostenlos vor Ort besprochen.
                        </p>
                        <div class="inline-flex items-center gap-2 bg-[#f8dac2]/30 text-[#ca1245] px-3 py-1.5 rounded-lg text-sm font-semibold border border-[#f3a397]/20">
                            ⚡ Express Same-Day nach Absprache möglich
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 2. TRUST-LEISTE -->
        <section class="bg-white border-y border-gray-100 py-8 mb-20">
            <div class="container mx-auto px-4 max-w-6xl">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
                    <div class="flex flex-col items-center gap-2">
                        <span class="text-3xl" aria-hidden="true">📅</span>
                        <span class="font-semibold text-gray-800">Kein Termin nötig</span>
                    </div>
                    <div class="flex flex-col items-center gap-2">
                        <span class="text-3xl" aria-hidden="true">⚡</span>
                        <span class="font-semibold text-gray-800">Fertig in 1–2 Tagen</span>
                    </div>
                    <div class="flex flex-col items-center gap-2">
                        <span class="text-3xl" aria-hidden="true">🧵</span>
                        <span class="font-semibold text-gray-800">Seit über 40 Jahren</span>
                    </div>
                    <div class="flex flex-col items-center gap-2">
                        <span class="text-3xl" aria-hidden="true">📍</span>
                        <span class="font-semibold text-gray-800">Düsseldorf-Eller · DHL-Paketshop</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- 3. LEISTUNGEN -->
        <section id="preise" class="container mx-auto px-4 max-w-6xl mb-20">
            <h2 class="text-3xl font-bold text-[#122738] mb-10 text-center">Unsere Leistungen im Überblick</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                    <h3 class="text-xl font-bold text-gray-900 mb-2">Hose kürzen</h3>
                    <p class="text-[#e94470] font-bold text-lg mb-2">ab 8 €</p>
                    <p class="text-sm text-gray-600 flex items-center gap-1.5"><span aria-hidden="true">⏱️</span> fertig in 1 Tag</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                    <h3 class="text-xl font-bold text-gray-900 mb-2">Kleid & Abendmode anpassen</h3>
                    <p class="text-[#e94470] font-bold text-lg mb-2">ab 14 €</p>
                    <p class="text-sm text-gray-600 flex items-center gap-1.5"><span aria-hidden="true">⏱️</span> nach Aufwand</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                    <h3 class="text-xl font-bold text-gray-900 mb-2">Reißverschluss erneuern</h3>
                    <p class="text-[#e94470] font-bold text-lg mb-2">ab 18 €</p>
                    <p class="text-sm text-gray-600 flex items-center gap-1.5"><span aria-hidden="true">⏱️</span> 1–2 Tage</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                    <h3 class="text-xl font-bold text-gray-900 mb-2">Sakko & Mantel</h3>
                    <p class="text-[#e94470] font-bold text-lg mb-2">ab 18 €</p>
                    <p class="text-sm text-gray-600 flex items-center gap-1.5"><span aria-hidden="true">⏱️</span> 2 Tage</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                    <h3 class="text-xl font-bold text-gray-900 mb-2">Bügelservice & Hemden</h3>
                    <p class="text-[#e94470] font-bold text-lg mb-2">ab 3,50 €</p>
                    <p class="text-sm text-gray-600 flex items-center gap-1.5"><span aria-hidden="true">⏱️</span> 1 Tag</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                    <h3 class="text-xl font-bold text-gray-900 mb-2">Gardinen & Heimtextilien</h3>
                    <p class="text-[#e94470] font-bold text-lg mb-2">auf Anfrage</p>
                    <p class="text-sm text-gray-600 flex items-center gap-1.5"><span aria-hidden="true">⏱️</span> nach Absprache</p>
                </div>
            </div>
        </section>

        <!-- 4. WARUM VALENTINA? -->
        <section class="container mx-auto px-4 max-w-6xl mb-20">
            <div class="bg-white rounded-3xl p-8 lg:p-12 shadow-sm border border-gray-100">
                <div class="lg:flex lg:gap-16 items-center">
                    <!-- Left -->
                    <div class="lg:w-1/2 mb-10 lg:mb-0">
                        <h2 class="text-3xl font-bold text-[#122738] mb-8">Warum zu Valentina?</h2>
                        <ul class="space-y-4">
                            <li class="flex items-start gap-3">
                                <span class="text-[#e94470] text-xl mt-0.5">✔</span>
                                <span class="text-gray-700 text-lg">Kein Termin nötig – einfach vorbeikommen</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="text-[#e94470] text-xl mt-0.5">✔</span>
                                <span class="text-gray-700 text-lg">Transparente Preise – kein versteckter Aufpreis</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="text-[#e94470] text-xl mt-0.5">✔</span>
                                <span class="text-gray-700 text-lg">Express Same-Day nach Absprache möglich</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="text-[#e94470] text-xl mt-0.5">✔</span>
                                <span class="text-gray-700 text-lg">DHL Paketshop direkt vor Ort</span>
                            </li>
                        </ul>
                    </div>
                    <!-- Right (Info-Karte) -->
                    <div class="lg:w-1/2">
                        <div id="anfahrt" class="bg-neutral-50 rounded-2xl p-6 md:p-8 border border-gray-200">
                            <div class="flex gap-4 mb-6 pb-6 border-b border-gray-200">
                                <div class="text-center w-1/3">
                                    <span class="block font-bold text-2xl text-[#122738]">40+</span>
                                    <span class="text-xs text-gray-500 uppercase tracking-wide">Jahre<br/>Erfahrung</span>
                                </div>
                                <div class="text-center w-1/3 border-x border-gray-200">
                                    <span class="block font-bold text-2xl text-[#122738]">1–2</span>
                                    <span class="text-xs text-gray-500 uppercase tracking-wide">Tage<br/>Bearbeitung</span>
                                </div>
                                <div class="text-center w-1/3">
                                    <span class="block font-bold text-2xl text-[#122738]">8 €</span>
                                    <span class="text-xs text-gray-500 uppercase tracking-wide">Einstiegs-<br/>preis</span>
                                </div>
                            </div>
                            
                            <div class="space-y-4 text-sm text-gray-700">
                                <div class="flex gap-3">
                                    <span class="text-[#e94470]" aria-hidden="true">📍</span>
                                    <div>
                                        <strong>Adresse</strong><br/>
                                        Dillenburger Weg 33a, 40229 Düsseldorf-Eller
                                    </div>
                                </div>
                                <div class="flex gap-3">
                                    <span class="text-[#e94470]" aria-hidden="true">📞</span>
                                    <div>
                                        <strong>Telefon</strong><br/>
                                        <a href="tel:+4921191737673" class="hover:text-[#e94470] transition-colors">0211 917 376 73</a>
                                    </div>
                                </div>
                                <div class="flex gap-3">
                                    <span class="text-[#e94470]" aria-hidden="true">🕒</span>
                                    <div>
                                        <strong>Öffnungszeiten</strong><br/>
                                        Mo, Di, Do, Fr: 10–13 & 15–18 Uhr<br/>
                                        Mittwoch: 10–13 Uhr<br/>
                                        Samstag: 10–13 Uhr<br/>
                                        Sonntag: Geschlossen
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 5. FAQ -->
        <section class="container mx-auto px-4 max-w-3xl mb-20">
            <h2 class="text-3xl font-bold text-[#122738] mb-8 text-center">Häufig gestellte Fragen</h2>
            <div class="space-y-4">
                <details class="group bg-white rounded-xl border border-gray-200 overflow-hidden [&_summary::-webkit-details-marker]:hidden" open>
                    <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-5 text-gray-900 group-open:bg-gray-50 transition-colors">
                        <span>Brauche ich einen Termin?</span>
                        <span class="transition group-open:rotate-180">
                            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                        </span>
                    </summary>
                    <div class="p-5 pt-0 text-gray-600 group-open:bg-gray-50">
                        Nein, ein Termin ist nicht nötig. Kommen Sie einfach während der Öffnungszeiten vorbei – wir nehmen Ihre Kleidung sofort entgegen und besprechen Preis und Bearbeitungszeit direkt vor Ort.
                    </div>
                </details>
                
                <details class="group bg-white rounded-xl border border-gray-200 overflow-hidden [&_summary::-webkit-details-marker]:hidden">
                    <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-5 text-gray-900 group-open:bg-gray-50 transition-colors">
                        <span>Wie lange dauert die Bearbeitung?</span>
                        <span class="transition group-open:rotate-180">
                            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                        </span>
                    </summary>
                    <div class="p-5 pt-0 text-gray-600 group-open:bg-gray-50">
                        In der Regel benötigen wir 1–2 Werktage für die meisten Änderungen. Express-Reparaturen am selben Tag sind nach Absprache für kleinere Arbeiten problemlos möglich.
                    </div>
                </details>
                
                <details class="group bg-white rounded-xl border border-gray-200 overflow-hidden [&_summary::-webkit-details-marker]:hidden">
                    <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-5 text-gray-900 group-open:bg-gray-50 transition-colors">
                        <span>Was kostet eine Hosenkürzung?</span>
                        <span class="transition group-open:rotate-180">
                            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                        </span>
                    </summary>
                    <div class="p-5 pt-0 text-gray-600 group-open:bg-gray-50">
                        Die einfache Hosenkürzung beginnt bereits ab 8 €. Wenn Sie den Erhalt der Originalnaht (z.B. bei Jeans) wünschen oder ein Stoßband für Anzughosen benötigen, liegen die Kosten bei ab 18 €.
                    </div>
                </details>

                <details class="group bg-white rounded-xl border border-gray-200 overflow-hidden [&_summary::-webkit-details-marker]:hidden">
                    <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-5 text-gray-900 group-open:bg-gray-50 transition-colors">
                        <span>Arbeiten Sie auch mit Leder?</span>
                        <span class="transition group-open:rotate-180">
                            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                        </span>
                    </summary>
                    <div class="p-5 pt-0 text-gray-600 group-open:bg-gray-50">
                        Ja, wir reparieren auch hochwertige Lederbekleidung professionell. Ein neuer Reißverschluss für eine Lederjacke kostet beispielsweise ab 35 €, das Erneuern des Innenfutters beginnt ab 30 €.
                    </div>
                </details>
                
                <details class="group bg-white rounded-xl border border-gray-200 overflow-hidden [&_summary::-webkit-details-marker]:hidden">
                    <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-5 text-gray-900 group-open:bg-gray-50 transition-colors">
                        <span>Wo genau in Düsseldorf?</span>
                        <span class="transition group-open:rotate-180">
                            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                        </span>
                    </summary>
                    <div class="p-5 pt-0 text-gray-600 group-open:bg-gray-50">
                        Unsere Änderungsschneiderei befindet sich in Düsseldorf-Eller, am Dillenburger Weg 33a, 40229 Düsseldorf. Unser Geschäft ist gut erreichbar und bietet Parkmöglichkeiten direkt vor der Tür.
                    </div>
                </details>
            </div>
        </section>

        <!-- 6. CTA-ABSCHNITT -->
        <section class="bg-[#122738] py-20 rounded-t-[3rem]">
            <div class="container mx-auto px-4 max-w-4xl text-center">
                <h2 class="text-4xl md:text-5xl font-bold text-white mb-8">Einfach vorbeikommen.</h2>
                <div class="flex flex-col sm:flex-row justify-center gap-4">
                    <a href="tel:+4921191737673" class="inline-flex items-center justify-center gap-2 bg-[#e94470] text-white px-8 py-4 rounded-full font-bold shadow-lg hover:shadow-xl hover:scale-105 hover:bg-[#ca1245] transition-all text-lg">
                        <span aria-hidden="true">📞</span> 0211 917 376 73
                    </a>
                    <a href="https://www.google.com/maps/place//data=!4m2!3m1!1s0x47b8cb99cead1003:0xcdc5770cd9c9ea36" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-white text-[#122738] px-8 py-4 rounded-full font-bold shadow-sm hover:bg-gray-100 hover:scale-105 transition-all text-lg">
                        <span aria-hidden="true">📍</span> Route planen
                    </a>
                </div>
            </div>
        </section>

    </main>

    <Footer />
</Layout>

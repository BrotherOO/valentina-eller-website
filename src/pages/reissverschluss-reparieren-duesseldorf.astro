---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.vue";
import Footer from "../components/Footer.astro";
---

<Layout
    title="Reißverschluss reparieren Düsseldorf – schnell & fair | Valentinas Nähstube"
    description="Reißverschluss reparieren in Düsseldorf – Schieber, Stopper oder kompletter Tausch. Schnell, fair und persönlich in Valentinas Nähstube Düsseldorf-Eller. Einfach vorbeikommen!"
>
    <Header client:load />

    <main class="pt-32 pb-20 bg-neutral-50/30">
        <div class="container mx-auto px-4 max-w-4xl">
            <!-- H1 & Intro -->
            <h1 class="text-3xl md:text-5xl font-bold text-[#122738] mb-6">
                Reißverschluss reparieren in Düsseldorf – einfach vorbeikommen
            </h1>
            <p class="text-xl text-gray-600 mb-12 leading-relaxed">
                Ein kaputter Reißverschluss bedeutet nicht das Ende Ihrer Lieblingsjacke oder -hose.<br/>
                In Valentinas Nähstube in Düsseldorf-Eller reparieren oder ersetzen wir Reißverschlüsse aller Art – schnell, sauber und zu fairen Festpreisen.<br/>
                Über 40 Jahre Erfahrung mit Jacken, Hosen und Kleidern. Kein Termin nötig – einfach vorbeikommen.
            </p>

            <!-- Was wir reparieren -->
            <section class="mb-16">
                <h2 class="text-2xl font-bold text-[#122738] mb-6">Was wir reparieren</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 flex items-start gap-3">
                        <span class="text-2xl" aria-hidden="true">🧥</span>
                        <div>
                            <strong class="block text-gray-900">Jacken & Mäntel</strong>
                            <span class="text-sm text-gray-600">Schieber, Stopper, kompletter Tausch</span>
                        </div>
                    </div>
                    <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 flex items-start gap-3">
                        <span class="text-2xl" aria-hidden="true">👖</span>
                        <div>
                            <strong class="block text-gray-900">Hosen & Jeans</strong>
                            <span class="text-sm text-gray-600">Hosenschlitz, Seitennähte, Zipper</span>
                        </div>
                    </div>
                    <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 flex items-start gap-3">
                        <span class="text-2xl" aria-hidden="true">👗</span>
                        <div>
                            <strong class="block text-gray-900">Kleider & Röcke</strong>
                            <span class="text-sm text-gray-600">Rücken-Reißverschluss, unsichtbarer RV</span>
                        </div>
                    </div>

                    <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 flex items-start gap-3">
                        <span class="text-2xl" aria-hidden="true">🛏️</span>
                        <div>
                            <strong class="block text-gray-900">Heimtextilien</strong>
                            <span class="text-sm text-gray-600">Bettwäsche, Kissen, Schlafsäcke</span>
                        </div>
                    </div>

                </div>
            </section>

            <!-- Preise -->
            <section class="mb-16">
                <h2 class="text-2xl font-bold text-[#122738] mb-6">Preise für Reißverschluss-Reparatur</h2>
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
                    <table class="w-full text-left">
                        <tbody class="divide-y divide-gray-100">
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="p-4 text-gray-800">
                                    <span class="font-bold block">Reißverschluss Jacke / Hose erneuern</span>
                                    <span class="text-sm text-gray-500">Dauer: 1–2 Tage</span>
                                </td>
                                <td class="p-4 font-bold text-[#e94470] text-right">ab 35 € (Leder)<br><span class="text-sm font-normal text-gray-500">ab 18 € (Stoff)</span></td>
                            </tr>
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="p-4 text-gray-800">
                                    <span class="font-bold block">Reißverschluss Kleid erneuern</span>
                                    <span class="text-sm text-gray-500">Dauer: 1–2 Tage</span>
                                </td>
                                <td class="p-4 font-bold text-[#e94470] text-right whitespace-nowrap">ab 18 €</td>
                            </tr>
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="p-4 text-gray-800">
                                    <span class="font-bold block">Reißverschluss Lederjacke erneuern</span>
                                    <span class="text-sm text-gray-500">Dauer: 1–2 Tage</span>
                                </td>
                                <td class="p-4 font-bold text-[#e94470] text-right whitespace-nowrap">ab 35 €</td>
                            </tr>
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="p-4 text-gray-800">
                                    <span class="font-bold block">Reißverschluss Tasche reparieren</span>
                                    <span class="text-sm text-gray-500">Dauer: Variiert</span>
                                </td>
                                <td class="p-4 font-bold text-[#e94470] text-right whitespace-nowrap">Auf Anfrage</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                        <h3 class="font-bold text-[#122738] mb-2 flex items-center gap-2">
                            <span aria-hidden="true">💶</span> Was kostet ein Reißverschluss?
                        </h3>
                        <p class="text-sm text-gray-600">Der Preis hängt vom Material (Stoff/Leder) und der Länge ab. Mindestpreis ab 18 €.</p>
                    </div>
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                        <h3 class="font-bold text-[#122738] mb-2 flex items-center gap-2">
                            <span aria-hidden="true">⏱️</span> Wie lange dauert es?
                        </h3>
                        <p class="text-sm text-gray-600">In der Regel 1–2 Werktage. Express am selben Tag nach Absprache möglich.</p>
                    </div>
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                        <h3 class="font-bold text-[#122738] mb-2 flex items-center gap-2">
                            <span aria-hidden="true">📅</span> Muss ich einen Termin machen?
                        </h3>
                        <p class="text-sm text-gray-600">Nein – einfach vorbeikommen. Adresse: Dillenburger Weg 33A, 40229 Düsseldorf-Eller.</p>
                    </div>
                </div>
            </section>

            <!-- Reparieren statt wegwerfen -->
            <section class="mb-16">
                <h2 class="text-2xl font-bold text-[#122738] mb-6">Reparieren statt wegwerfen – warum es sich lohnt</h2>
                <div class="prose prose-lg text-gray-600">
                    <p>
                        Ein neuer Reißverschluss kostet einen Bruchteil eines neuen Kleidungsstücks. Valentina repariert täglich Lieblingsteile die schon verloren geglaubt waren – Jacken die seit 10 Jahren begleiten, Hosen die perfekt sitzen, Taschen mit Geschichte.
                    </p>
                    <p>
                        Nachhaltigkeit beginnt in der Schneiderei: Reparieren verlängert die Lebensdauer Ihrer Kleidung und schont gleichzeitig den Geldbeutel.
                    </p>
                </div>
            </section>

            <!-- So läuft die Reparatur ab -->
            <section class="mb-16">
                <h2 class="text-2xl font-bold text-[#122738] mb-6">So läuft die Reparatur ab</h2>
                <ol class="space-y-4">
                    <li class="flex gap-4 items-start">
                        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-[#e94470] text-white flex items-center justify-center font-bold">1</span>
                        <p class="text-gray-700 pt-1">Kleidungsstück mitbringen – kein Termin nötig, einfach zu unseren Öffnungszeiten vorbeikommen</p>
                    </li>
                    <li class="flex gap-4 items-start">
                        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-[#e94470] text-white flex items-center justify-center font-bold">2</span>
                        <p class="text-gray-700 pt-1">Valentina schaut sich den Schaden direkt an und gibt Ihnen sofort einen Kostenvoranschlag</p>
                    </li>
                    <li class="flex gap-4 items-start">
                        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-[#e94470] text-white flex items-center justify-center font-bold">3</span>
                        <p class="text-gray-700 pt-1">Reparatur – einfache Reparaturen oft noch am selben Tag</p>
                    </li>
                    <li class="flex gap-4 items-start">
                        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-[#e94470] text-white flex items-center justify-center font-bold">4</span>
                        <p class="text-gray-700 pt-1">Kleidungsstück abholen – wie neu</p>
                    </li>
                </ol>
                
                <div class="mt-8 bg-[#f8dac2]/30 p-6 rounded-2xl border border-[#f3a397]/20 flex gap-4 items-start">
                    <span class="text-2xl" aria-hidden="true">💡</span>
                    <div>
                        <p class="text-gray-700">
                            <strong>Schnelle Reparaturen</strong> wie Schieber erneuern oder Stopper ersetzen erledigen wir oft sofort während Sie warten – ohne extra Wartezeit.
                        </p>
                    </div>
                </div>
            </section>

            <!-- Häufige Fragen -->
            <section class="mb-16">
                <h2 class="text-2xl font-bold text-[#122738] mb-6">Häufige Fragen zur Reißverschluss-Reparatur</h2>
                <div class="space-y-6">
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                        <h3 class="font-bold text-lg text-gray-900 mb-2">Kann man nur den Schieber tauschen ohne den ganzen RV?</h3>
                        <p class="text-gray-600">Ja, wenn die Spirale noch intakt ist. Das ist die günstigste Lösung und reicht oft völlig aus.</p>
                    </div>
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                        <h3 class="font-bold text-lg text-gray-900 mb-2">Wie lange dauert die Reparatur?</h3>
                        <p class="text-gray-600">Einfache Reparaturen (Schieber, Stopper) oft sofort. Kompletter Tausch in der Regel 1–3 Werktage.</p>
                    </div>

                </div>
            </section>

            <!-- Anfahrt & Öffnungszeiten -->
            <section class="mb-16 bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
                <h2 class="text-2xl font-bold text-[#122738] mb-6">Anfahrt & Öffnungszeiten</h2>
                <div class="text-gray-700 space-y-2 mb-8">
                    <p class="font-bold text-gray-900">Valentinas Nähstube</p>
                    <p>Dillenburger Weg 33A, 40229 Düsseldorf-Eller</p>
                    <p>Telefon: <a href="tel:021191737673" class="text-[#e94470] hover:underline">0211 91737673</a></p>
                    <div class="mt-4">
                        <p>Mo, Di, Do, Fr: 10:00–13:00 und 15:00–18:00</p>
                        <p>Mittwoch & Samstag: 10:00–13:00</p>
                    </div>
                    <div class="mt-4 pt-4 border-t border-gray-100 text-sm">
                        <p>Gut erreichbar mit Bus und Bahn – Haltestelle Eller Mitte.</p>
                        <p>Parkplätze direkt vor dem Geschäft vorhanden.</p>
                    </div>
                </div>

                <a
                    href="https://www.google.com/maps/place//data=!4m2!3m1!1s0x47b8cb99cead1003:0xcdc5770cd9c9ea36"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 bg-[#e94470] text-white px-8 py-4 rounded-full font-bold shadow-lg hover:shadow-xl hover:scale-105 hover:bg-[#ca1245] transition-all"
                >
                    Route in Google Maps planen &rarr;
                </a>
            </section>

        </div>
    </main>
    <Footer />
</Layout>

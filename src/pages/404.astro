---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.vue";
import Footer from "../components/Footer.astro";
---

<Layout
    title="Seite nicht gefunden | Valentinas Nähstube"
    description="Die gesuchte Seite konnte leider nicht gefunden werden."
>
    <Header client:load />

    <main class="pt-32 pb-20 bg-neutral-50/30 flex flex-col items-center justify-center min-h-[75vh]">
        <div class="container mx-auto px-4 max-w-2xl text-center">
            <span class="text-8xl mb-6 block" aria-hidden="true">🧵</span>
            <h1 class="text-6xl md:text-8xl font-bold text-[#e94470] mb-6">404</h1>
            <h2 class="text-3xl md:text-4xl font-bold text-[#122738] mb-6">
                Oh je, da haben wir uns wohl vernäht!
            </h2>
            <p class="text-xl text-gray-600 mb-10 leading-relaxed">
                Der Faden ist ab – die Seite, nach der Sie suchen, existiert leider nicht oder wurde verschoben. Keine Sorge, wir flicken das wieder!
            </p>

            <a
                href="/"
                class="inline-flex items-center gap-2 bg-[#e94470] text-white px-8 py-4 rounded-full font-bold shadow-lg hover:shadow-xl hover:scale-105 hover:bg-[#ca1245] transition-all"
            >
                Zurück zur Startseite &rarr;
            </a>
        </div>
    </main>
    <Footer />
</Layout>

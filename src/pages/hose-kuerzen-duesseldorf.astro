---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.vue";
import Footer from "../components/Footer.astro";
---

<Layout
    title="Hose kürzen Düsseldorf – ab 8 € | Valentinas Nähstube Eller"
    description="Hose kürzen in Düsseldorf ab 8 €. Schnell, präzise und fair – in Valentinas Nähstube in Düsseldorf-Eller. Einfach vorbeikommen, kein Termin nötig."
>
    <Header client:load />

    <main class="pt-32 pb-20 bg-neutral-50/30">
        <div class="container mx-auto px-4 max-w-4xl">
            <!-- H1 & Intro -->
            <h1 class="text-3xl md:text-5xl font-bold text-[#122738] mb-6">
                Hose kürzen in Düsseldorf – ab 8 €
            </h1>
            <p class="text-xl text-gray-600 mb-12 leading-relaxed">
                Hosen die zu lang sind nerven – aber die Lösung ist einfach.<br/>
                In Valentinas Nähstube in Düsseldorf-Eller kürzen wir Ihre Hose schnell, sauber und zu einem fairen Festpreis ab 8 €.<br/>
                Kein Termin nötig – einfach vorbeikommen.
            </p>

            <!-- Preise -->
            <section class="mb-16">
                <h2 class="text-2xl font-bold text-[#122738] mb-6">Preise für Hosenkürzungen</h2>
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                    <table class="w-full text-left">
                        <tbody class="divide-y divide-gray-100">
                            <tr class="hover:bg-gray-50 transition-colors"><td class="p-4 text-gray-800">Hose kürzen (einfacher Saum)</td><td class="p-4 font-bold text-[#e94470] text-right whitespace-nowrap">ab 8 €</td></tr>
                            <tr class="hover:bg-gray-50 transition-colors"><td class="p-4 text-gray-800">Hose kürzen (mit Bügelfalte)</td><td class="p-4 font-bold text-[#e94470] text-right whitespace-nowrap">ab 12 €</td></tr>
                            <tr class="hover:bg-gray-50 transition-colors"><td class="p-4 text-gray-800">Hose kürzen (Jeans, Original-Saum)</td><td class="p-4 font-bold text-[#e94470] text-right whitespace-nowrap">ab 14 €</td></tr>
                            <tr class="hover:bg-gray-50 transition-colors"><td class="p-4 text-gray-800">Hose kürzen (Anzughose)</td><td class="p-4 font-bold text-[#e94470] text-right whitespace-nowrap">ab 12 €</td></tr>
                            <tr class="hover:bg-gray-50 transition-colors"><td class="p-4 text-gray-800">Taille enger/weiter</td><td class="p-4 font-bold text-[#e94470] text-right whitespace-nowrap">ab 15 €</td></tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- So funktioniert es -->
            <section class="mb-16">
                <h2 class="text-2xl font-bold text-[#122738] mb-6">So funktioniert es</h2>
                <ol class="space-y-4">
                    <li class="flex gap-4 items-start">
                        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-[#e94470] text-white flex items-center justify-center font-bold">1</span>
                        <p class="text-gray-700 pt-1">Hose anziehen und zu uns kommen – Dillenburger Weg 33A, Düsseldorf-Eller</p>
                    </li>
                    <li class="flex gap-4 items-start">
                        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-[#e94470] text-white flex items-center justify-center font-bold">2</span>
                        <p class="text-gray-700 pt-1">Valentina steckt die gewünschte Länge direkt am Körper ab</p>
                    </li>
                    <li class="flex gap-4 items-start">
                        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-[#e94470] text-white flex items-center justify-center font-bold">3</span>
                        <p class="text-gray-700 pt-1">Hose abholen – fertig, perfekt sitzend</p>
                    </li>
                </ol>
                
                <div class="mt-8 bg-[#f8dac2]/30 p-6 rounded-2xl border border-[#f3a397]/20 flex gap-4 items-start">
                    <span class="text-2xl" aria-hidden="true">💡</span>
                    <div>
                        <strong class="block text-gray-900 mb-1">Tipp: Sie müssen die Hose nicht vorher anziehen.</strong>
                        <p class="text-gray-600">Bei uns gibt es eine Umkleidekabine direkt im Laden – einfach die Hose mitbringen und bei uns wechseln. Das gilt auch für Kleider, Röcke und Jacken.</p>
                    </div>
                </div>
            </section>

            <!-- Warum Valentinas Nähstube? -->
            <section class="mb-16">
                <h2 class="text-2xl font-bold text-[#122738] mb-6">Warum Valentinas Nähstube?</h2>
                <ul class="space-y-3 text-gray-700">
                    <li class="flex items-center gap-3"><span class="w-2 h-2 rounded-full bg-[#e94470]"></span>Über 40 Jahre Erfahrung mit allen Hosentypen</li>
                    <li class="flex items-center gap-3"><span class="w-2 h-2 rounded-full bg-[#e94470]"></span>Faire Festpreise – keine versteckten Kosten</li>
                    <li class="flex items-center gap-3"><span class="w-2 h-2 rounded-full bg-[#e94470]"></span>Schnelle Bearbeitung – oft am selben oder nächsten Tag</li>
                    <li class="flex items-center gap-3"><span class="w-2 h-2 rounded-full bg-[#e94470]"></span>Persönliche Beratung direkt in Eller</li>
                    <li class="flex items-center gap-3"><span class="w-2 h-2 rounded-full bg-[#e94470]"></span>Kein Termin nötig – einfach vorbeikommen</li>
                </ul>
            </section>

            <!-- Anfahrt & Öffnungszeiten -->
            <section class="mb-16 bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
                <h2 class="text-2xl font-bold text-[#122738] mb-6">Anfahrt & Öffnungszeiten</h2>
                <div class="text-gray-700 space-y-2 mb-8">
                    <p class="font-bold text-gray-900">Valentinas Nähstube</p>
                    <p>Dillenburger Weg 33A</p>
                    <p>40229 Düsseldorf-Eller</p>
                    <div class="mt-4">
                        <p>Mo, Di, Do, Fr: 10:00–13:00 und 15:00–18:00</p>
                        <p>Mittwoch & Samstag: 10:00–13:00</p>
                    </div>
                    <div class="mt-4 pt-4 border-t border-gray-100 text-sm">
                        <p>Gut erreichbar mit Bus und Bahn – Haltestelle Eller Mitte.</p>
                        <p>Parkplätze direkt vor dem Geschäft vorhanden.</p>
                    </div>
                </div>

                <a
                    href="https://www.google.com/maps/place//data=!4m2!3m1!1s0x47b8cb99cead1003:0xcdc5770cd9c9ea36"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 bg-[#e94470] text-white px-8 py-4 rounded-full font-bold shadow-lg hover:shadow-xl hover:scale-105 hover:bg-[#ca1245] transition-all"
                >
                    Route in Google Maps planen &rarr;
                </a>
            </section>

        </div>
    </main>
    <Footer />
</Layout>
